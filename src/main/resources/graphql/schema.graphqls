type Transaction {
	id: ID!,
	amount: Int!,
	date: String!,
	description: String
}

type Query {
  transaction(id: ID!): Transaction,
  transactions(startDate: String, endDate: String, sort: Sort): [Transaction!]!,
}

type Mutation {
	updateTransactionDescription(description: String!, id: ID!): Transaction
}

enum Sort {
 ASC,
 DESC
}