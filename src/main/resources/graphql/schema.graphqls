type Transaction {
	id: ID!,
	amount: Int!,
	date: String!,
	description: String
}

type Query {
  transaction(id: ID!): Transaction,
  transactions(startDate: String, endDate: String, sort: Sort, sortBy: SortBy): [Transaction!]!,
}

type Mutation {
	updateTransactionDescription(description: String!, id: ID!): Transaction
}

enum Sort {
 ASC,
 DESC
}

enum SortBy {
	DATE,
	AMOUNT
}