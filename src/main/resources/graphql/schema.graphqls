scalar Date

type Transaction {
	id: ID!,
	amount: Int!,
	date: Date!,
	description: String
}

type Account {
	accountId: ID!
	name: String!
}

type Query {
  transaction(id: ID!): Transaction,
  transactions(startDate: Date, endDate: Date, sort: Sort, sortBy: SortBy, accountId: ID): [Transaction!]!,
}

type Mutation {
	updateTransactionDescription(description: String!, id: ID!): Transaction
	createAccount(name: String!): Account
}

enum Sort {
 ASC,
 DESC
}

enum SortBy {
	DATE,
	AMOUNT
}